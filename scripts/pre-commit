#!/bin/bash

# 自动递增版本号的 pre-commit hook
# 安装方法: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

PUBSPEC="pubspec.yaml"

# 检查 pubspec.yaml 是否存在
if [ ! -f "$PUBSPEC" ]; then
    echo "Error: $PUBSPEC not found"
    exit 1
fi

# 获取当前版本号
CURRENT_VERSION=$(grep "^version:" "$PUBSPEC" | sed 's/version: //' | tr -d ' ')
echo "Current version: $CURRENT_VERSION"

# 解析版本号
MAJOR=$(echo "$CURRENT_VERSION" | cut -d'.' -f1)
MINOR=$(echo "$CURRENT_VERSION" | cut -d'.' -f2)
PATCH=$(echo "$CURRENT_VERSION" | cut -d'.' -f3 | cut -d'+' -f1)

# 递增 patch 版本号
PATCH=$((PATCH + 1))

# 构建新版本号
NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"

# 更新 pubspec.yaml
sed -i "s/^version: $CURRENT_VERSION/version: $NEW_VERSION/" "$PUBSPEC"

echo "Version incremented: $CURRENT_VERSION -> $NEW_VERSION"

# 添加修改到 git
git add "$PUBSPEC"

exit 0

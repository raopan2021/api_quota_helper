<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApiQuotaHelper.ViewModels"
        x:Class="ApiQuotaHelper.MainWindow"
        Title="API 额度助手"
        Width="480" Height="720"
        WindowStartupLocation="CenterScreen">

  <DockPanel>
    <!-- 顶部栏 -->
    <Border DockPanel.Dock="Top" Background="#F3F3F3" Padding="12">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Text="API 额度助手" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Content="设置" Command="{Binding OpenSettingsCommand}" Margin="4,0" Padding="8,4"/>
        <Button Grid.Column="2" Content="日志" Command="{Binding OpenLogsCommand}" Margin="4,0" Padding="8,4"/>
        <Button Grid.Column="3" Content="刷新" Command="{Binding RefreshAllCommand}" Margin="4,0" Padding="8,4"/>
      </Grid>
    </Border>

    <!-- 主内容 -->
    <Grid>
      <!-- 无账户空状态 -->
      <StackPanel IsVisible="{Binding !Accounts.Count}" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="暂无账户" FontSize="18" HorizontalAlignment="Center" Opacity="0.6"/>
        <TextBlock Text="点击下方 + 按钮添加账户" FontSize="13" HorizontalAlignment="Center" Opacity="0.4" Margin="0,8,0,0"/>
      </StackPanel>

      <!-- 账户列表 -->
      <ScrollViewer IsVisible="{Binding Accounts.Count}" Margin="12">
        <ItemsControl ItemsSource="{Binding Accounts}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AccountVm">
              <Border Background="#F8F8F8" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                  <TextBlock Text="{Binding Account.Username}" FontWeight="Bold" FontSize="16"/>
                  <TextBlock Text="••••••••" Opacity="0.5" FontSize="12" Margin="0,2,0,0"/>
                  <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Margin="0,8,0,0"/>
                  <TextBlock Text="{Binding Error}" Foreground="Red" IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                  <StackPanel IsVisible="{Binding Quota, Converter={x:Static ObjectConverters.IsNotNull}}" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Quota.PlanName}" FontSize="13" Opacity="0.8"/>
                    <ProgressBar Value="{Binding RemainingPercent}" Maximum="100" Height="6" Margin="0,6,0,0"/>
                    <Grid Margin="0,4,0,0">
                      <TextBlock Text="{Binding Quota.AmountUsed, StringFormat='已用: {0:F1}'}" FontSize="12" HorizontalAlignment="Left" Opacity="0.7"/>
                      <TextBlock Text="{Binding Quota.Remaining, StringFormat='剩余: {0:F1}'}" FontSize="12" HorizontalAlignment="Right" Opacity="0.7"/>
                    </Grid>
                    <TextBlock Text="{Binding Quota.NextResetTime, StringFormat='重置时间: {0}'}" FontSize="12" Opacity="0.7" Margin="0,2,0,0" IsVisible="{Binding Quota.NextResetTime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                      <Button Content="刷新" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).RefreshOneCommand}" CommandParameter="{Binding}" Padding="8,4" Margin="0,0,8,0"/>
                      <Button Content="编辑" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).ShowEditCommand}" CommandParameter="{Binding}" Padding="8,4" Margin="0,0,8,0"/>
                      <Button Content="删除" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).DeleteAccountCommand}" CommandParameter="{Binding}" Padding="8,4"/>
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- 添加按钮 -->
      <Button Content="+" Command="{Binding ShowAddCommand}"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,24,24" FontSize="24" Padding="16,8"
              IsVisible="{Binding !ShowAddDialog}"/>
    </Grid>

    <!-- 添加/编辑对话框遮罩 -->
    <Panel IsVisible="{Binding ShowAddDialog}">
      <Border Background="#80000000"/>
      <Border Background="White" CornerRadius="12" Padding="24" MaxWidth="360"
              VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock FontSize="18" FontWeight="Bold">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0}">
                <Binding Path="EditingAccount" Converter="{x:Static ObjectConverters.IsNull}" ConverterParameter="添加账户"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock Text="用户名"/>
          <TextBox Text="{Binding DialogUsername}" Watermark="username"/>
          <TextBlock Text="Token"/>
          <TextBox Text="{Binding DialogToken}" Watermark="sk-xxxx" PasswordChar="*"/>
          <TextBlock Text="{Binding DialogError}" Foreground="Red"
                     IsVisible="{Binding DialogError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="取消" Command="{Binding CancelDialogCommand}" Padding="12,6"/>
            <Button Content="保存" Command="{Binding SaveDialogCommand}" Padding="12,6"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Panel>

    <!-- 设置面板遮罩 -->
    <Panel IsVisible="{Binding ShowSettings}">
      <Border Background="#80000000"/>
      <Border Background="White" CornerRadius="12" Padding="24" MinWidth="360"
              VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="16">
          <Grid><TextBlock Text="设置" FontSize="20" FontWeight="Bold"/><Button Content="✕" Command="{Binding CloseSettingsCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"/></Grid>
          <Separator/>
          <CheckBox Content="深色模式" IsChecked="{Binding IsDarkMode}" Command="{Binding ToggleDarkModeCommand}"/>
          <StackPanel>
            <TextBlock Text="刷新间隔" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="30秒" Command="{Binding UpdateRefreshIntervalCommand}" CommandParameter="30" Padding="8,4"/>
              <Button Content="1分钟" Command="{Binding UpdateRefreshIntervalCommand}" CommandParameter="60" Padding="8,4"/>
              <Button Content="5分钟" Command="{Binding UpdateRefreshIntervalCommand}" CommandParameter="300" Padding="8,4"/>
              <Button Content="10分钟" Command="{Binding UpdateRefreshIntervalCommand}" CommandParameter="600" Padding="8,4"/>
            </StackPanel>
            <TextBlock Text="{Binding RefreshIntervalSec, StringFormat='当前: {0}秒'}" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Panel>

    <!-- 日志面板遮罩 -->
    <Panel IsVisible="{Binding ShowLogs}">
      <Border Background="#80000000"/>
      <Border Background="White" CornerRadius="12" Padding="16" MinWidth="420" MaxHeight="600"
              VerticalAlignment="Center" HorizontalAlignment="Center">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="网络日志" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
              <Button Content="清空" Command="{Binding ClearLogsCommand}" Padding="8,4"/>
              <Button Content="✕" Command="{Binding CloseLogsCommand}" Background="Transparent" BorderThickness="0" Padding="8,4"/>
            </StackPanel>
          </Grid>

          <!-- 日志类型筛选 -->
          <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding LogTypes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="8"/></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Content="{Binding}" Padding="8,4"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectLogTypeCommand}"
                          CommandParameter="{Binding}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Logs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:LogEntryVm">
                  <Border Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                      <Grid>
                        <TextBlock Text="{Binding Time}" FontSize="12" Opacity="0.6"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="12">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} {1}">
                              <Binding Path="LogType"/>
                              <Binding Path="Username"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </Grid>
                      <TextBlock Text="{Binding ResponseMessage}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Panel>
  </DockPanel>
</Window>
